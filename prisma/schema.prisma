// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Models ---

model User {
  id              String    @id @default(uuid())
  username        String    @unique // Persian supported
  email           String    @unique
  passwordHash    String
  role            String    @default("USER") // USER, ADMIN
  isVerified      Boolean   @default(false)
  twoFactorEnabled Boolean  @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  profile         Profile?
  sentFriendReq   Friendship[] @relation("Requester")
  recvFriendReq   Friendship[] @relation("Target")
  sentMessages     Message[]    @relation("SentMessages")
  receivedMessages Message[]    @relation("ReceivedMessages")
  lobbyMembers    LobbyMember[]
  notifications   Notification[]
  xpLogs          XPLog[]
  subscriptions   Subscription[]
  auditLogs       AuditLog[]
  userGames       UserGame[]
  badges          UserBadge[]
  hostedLobbies   Lobby[]      @relation("LobbyHost")
  ownedChannels   Channel[]    @relation("OwnedChannels")
  channelMemberships ChannelMember[]
  settings        UserSettings?
  activities      Activity[]
  invitesSent     Referral[]   @relation("Inviter")
  invitationReceived Referral?   @relation("Invitee")
  paymentRequests PaymentRequest[]
  lobbyBans       LobbyBan[]
  devices         ConnectedDevice[]
}

model UserSettings {
  userId          String         @id
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Notification Settings
  receiveFriendRequests Boolean    @default(true)
  receiveLobbyInvites   Boolean    @default(true)
  showMentionAlerts     Boolean    @default(true)
  
  // UI Settings
  theme                 String     @default("dark") // dark, light, high-contrast
  language              String     @default("fa")   // fa, en
  showOnlineStatus     Boolean     @default(true)
  reduceAnimations     Boolean     @default(false)
}

model Profile {
  userId          String         @id
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  bio             String?        // Persian/RTL
  avatarUrl       String?
  bannerUrl       String?
  level           Int            @default(1)
  xp              Int            @default(0)
  membershipType  String         @default("NONE") // NONE, PLUS, VIP
  region          String         @default("IR")   // IR, TR, EU, ME
  lastActivity    DateTime       @default(now())
  totalLobbiesJoined Int          @default(0)
  vipMetadata     String?        // JSON string for Elite Settings (frames, effects, etc)
}

model Friendship {
  id              String           @id @default(uuid())
  requesterId     String
  targetId        String
  status          String           @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  isFavorite      Boolean          @default(false)
  isMuted         Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  requester       User             @relation("Requester", fields: [requesterId], references: [id])
  target          User             @relation("Target", fields: [targetId], references: [id])

  @@unique([requesterId, targetId])
  @@index([requesterId, status])
}

model Game {
  id              String   @id @default(uuid())
  title           String   @unique // Persian
  iconUrl         String?
  bannerUrl       String?
  genres          String?  // JSON array of strings (names) or IDs
  regions         String?  // JSON array: ["IR", "EU", etc]
  metadata        String?  // JSON string: { features: [{ name: "Mode", options: [] }] }
  lobbies         Lobby[]
  channels        Channel[]
  userGames       UserGame[]
  badgeId         String?
  badge           Badge?   @relation(fields: [badgeId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  iconUrl     String   
  isSpecial   Boolean  @default(false) 
  category    String   @default("STANDARD") // STANDARD, GAME, SPECIAL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserBadge[]
  games       Game[]
}

model UserBadge {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  isPinned  Boolean  @default(false)
  earnedAt  DateTime @default(now())

  @@id([userId, badgeId])
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique // e.g. "FPS", "RPG"
  icon      String?  // Optional icon name or URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Channel {
  id              String   @id @default(uuid())
  title           String   // Persian: "Global", "News", "LFG"
  gameId          String?
  game            Game?    @relation(fields: [gameId], references: [id])
  type            String   @default("PUBLIC") // PUBLIC, ELITE, NEWS
  ownerId         String?
  owner           User?    @relation("OwnedChannels", fields: [ownerId], references: [id])
  avatarUrl       String?
  metadata        String?
  inviteCode      String?  @unique
  members         ChannelMember[]
  messages        Message[]
}

model ChannelMember {
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String   @default("MEMBER") // OWNER, MEMBER
  joinedAt        DateTime @default(now())

  @@id([channelId, userId])
}

model Message {
  id              Int      @id @default(autoincrement())
  channelId       String?
  channel         Channel? @relation(fields: [channelId], references: [id])
  lobbyId         String?
  lobby           Lobby?   @relation(fields: [lobbyId], references: [id])
  senderId        String
  sender          User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId      String?
  receiver        User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content         String   // Persian/RTL
  replyToId       Int?
  replyTo         Message? @relation("Thread", fields: [replyToId], references: [id])
  replies         Message[] @relation("Thread")
  reactions       String?  // JSON string
  metadata        String?  // JSON string
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([channelId, createdAt])
  @@index([lobbyId, createdAt])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

model Lobby {
  id              String      @id @default(uuid())
  gameId          String
  game            Game        @relation(fields: [gameId], references: [id])
  title           String      // Persian
  hostId          String
  host            User        @relation("LobbyHost", fields: [hostId], references: [id])
  maxPlayers      Int         @default(5)
  password        String?
  region          String      @default("IR") // IR, TR, EU, ME
  status          String      @default("WAITING") // WAITING, STARTING, IN_PROGRESS, FINISHED
  mode            String?     // e.g. "Competitive", "Casual"
  selectedMaps    String?     // JSON string or comma-separated
  description     String?     // Lobby description
  metadata        String?     // JSON string for dynamic features
  skillLevel      String?     // e.g. "Silver - Global"
  micRequired     Boolean     @default(false)
  isPrivate       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt @default(now())

  members         LobbyMember[]
  messages        Message[]
  bans            LobbyBan[]

  @@index([hostId])
}

model UserGame {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, gameId])
}

model LobbyMember {
  lobbyId         String
  lobby           Lobby     @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  role            String    @default("PLAYER") // HOST, PLAYER, SPECTATOR
  isReady         Boolean   @default(false)
  micStatus       Boolean   @default(false) // Muted/Unmuted
  
  @@id([lobbyId, userId])
}

model Notification {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String           // FRIEND_REQUEST, FRIEND_ACCEPTED, MENTION, LOBBY_INVITE, etc.
  senderId        String?
  referenceId     String?          // Polymorphic: messageId, lobbyId, requestId
  data            String?          // JSON string
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())
}

model XPLog {
  id              Int            @id @default(autoincrement())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  source          String         // LOBBY_JOIN, MATCH_START, etc.
  amount          Int
  timestamp       DateTime       @default(now())

  @@index([userId, timestamp])
}

model Subscription {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String         // PLUS, VIP
  expiresAt       DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
}

model PaymentRequest {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String         // PLUS, VIP
  amount          Int
  status          String         @default("PENDING") // PENDING, APPROVED, REJECTED
  receiptImageUrl String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, status])
}

model Referral {
  id              String         @id @default(uuid())
  inviterId       String         // The user who invited
  inviter         User           @relation("Inviter", fields: [inviterId], references: [id])
  inviteeId       String         @unique // The new user
  invitee         User           @relation("Invitee", fields: [inviteeId], references: [id])
  referralCode    String
  createdAt       DateTime       @default(now())
}

model AuditLog {
  id              Int      @id @default(autoincrement())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  action          String   // "LOGIN", "REGISTER", etc.
  ipAddress       String?
  metadata        String?
  createdAt       DateTime @default(now())
}

model Activity {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // e.g. LOBBY_JOIN, LEVEL_UP
  data            String?  // JSON
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

model LobbyBan {
  lobbyId String
  userId  String
  lobby   Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([lobbyId, userId])
}

model ConnectedDevice {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName String
  os        String
  browser   String
  ipAddress String
  lastActive DateTime @default(now())
  createdAt DateTime @default(now())
}
